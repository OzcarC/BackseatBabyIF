    <result xml:space="preserve">You see nothing special about the rattle.&#x000A;&#x000A;It is priced at $30.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
  </item>
