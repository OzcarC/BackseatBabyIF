  <item nodeId="node-620">
    <command xml:space="preserve">x skeeball</command>
    <result xml:space="preserve">A game of skill, potential to gain upwards of 100 tickets. You are not very skilled.&#x000A;&#x000A;It costs $20 to play.&#x000A;&#x000A;&gt;</result>
