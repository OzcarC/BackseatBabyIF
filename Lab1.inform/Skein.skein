  <item nodeId="node-652">
    <command xml:space="preserve">out</command>
    <result xml:space="preserve">The Intersection&#x000A;There is an Arcade to the west, a large Gas Station to the east and the Car in the Intersection.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-653"/>
    </children>
  </item>
  <item nodeId="node-653">
    <command xml:space="preserve">in</command>
    <result xml:space="preserve">Car&#x000A;A beat up red sedan with no headlights, just stickers. Outside is a busy intersection.&#x000A;&#x000A;You can see a Baby and a diaper bag (in which are diapers, a bottle, old fruit snacks and rash cream) here.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-654"/>
    </children>
